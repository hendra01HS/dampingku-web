rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /modul/{modulId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /pesanan/{pesananId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
    match /video/{videoId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
